# ============================================================
# Video Generation Hub - Environment Variables
# ============================================================
# Provider API keys are NOT set here anymore. Add them via the
# Settings page in the UI (they're encrypted with SECRETS_KEY
# and stored in the database). You can configure multiple
# credentials per provider and pick one when creating a job.
# ============================================================

# ---------- App ----------
NODE_ENV=development
# Public URL of the app, used for building webhook callback URLs.
APP_BASE_URL=http://localhost:3000

# Used to validate incoming webhook callbacks. Generate with `openssl rand -hex 32`.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Used to encrypt provider secrets at rest (AES-256-GCM). CHANGE IN PRODUCTION.
# If you rotate this value, all existing credentials become unreadable.
SECRETS_KEY=change-me-to-a-long-random-string-at-least-16-chars

# ---------- Database ----------
DATABASE_URL=postgres://vghub:vghub@postgres:5432/vghub

# ---------- Redis (BullMQ) ----------
REDIS_URL=redis://redis:6379

# ---------- Object Storage (S3 compatible / MinIO) ----------
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vghub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
