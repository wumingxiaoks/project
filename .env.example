# ============================================================
# Video Generation Hub - Environment Variables
# ============================================================

# ---------- App ----------
NODE_ENV=development
# Public URL of the app, used for building webhook callback URLs.
# In Docker Compose set this to something reachable from the providers.
# For local dev you can use https://<your-ngrok>.ngrok.app
APP_BASE_URL=http://localhost:3000

# Shared secret for validating webhook callbacks. Generate with `openssl rand -hex 32`.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ---------- Database ----------
DATABASE_URL=postgres://vghub:vghub@postgres:5432/vghub

# ---------- Redis (BullMQ) ----------
REDIS_URL=redis://redis:6379

# ---------- Object Storage (S3 compatible / MinIO) ----------
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=vghub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---------- Providers ----------
# Replicate: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Kling (Kuaishou): https://app.klingai.com/global/dev-center
# Uses JWT signed with AK/SK
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE=https://api-singapore.klingai.com

# MiniMax Hailuo: https://platform.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=https://api.minimaxi.chat
